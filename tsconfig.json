{
  "extends": "./node_modules/gts/tsconfig-google.json",
  "compilerOptions": {
    "composite": false,
    "declaration": true,
    "incremental": false,
    "rootDir": "./src",
    "outDir": "dist",
    "strict": true,
    "moduleResolution": "nodenext",
    "resolveJsonModule": false,
    "module": "nodenext",
    "lib": [
      "es2016",
      "dom"
    ],
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**.*ts"
  ],
  "exclude": [
    "src/**/__tests__/**"
  ]
}
